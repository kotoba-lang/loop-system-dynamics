;; Real, dated, git-verified input facts for etzhayyim's com-etzhayyim-*
;; actor-repo -> com-junkawasaki/root manifest/west.yml registration
;; pipeline, modeled as an XMILE (OASIS 1.0) stock-flow system via
;; kotoba-lang/org-oasis-open-xmile. Same shape as
;; resources/cloud-itonami-fleet-xmile-seed.edn -- see
;; src/loop_system_dynamics/etzhayyim_actors_xmile.cljs (a thin wrapper over
;; loop_system_dynamics/fleet_registration_xmile.cljs, the generic core
;; both this and cloud-itonami's own model now share).
;;
;; Unlike cloud-itonami's isic/isco/iso/lei/... (real, distinct
;; classification-system prefixes), com-etzhayyim-* repo names do not carry
;; a second real structural prefix worth splitting on: `gh api
;; orgs/etzhayyim/repos --paginate .name` grouped by the token after
;; `com-etzhayyim-` shows one large bucket (`app`, 336/613 = 54.8%) and a
;; long tail of ~130 one-off single-repo prefixes with no shared semantic
;; category (`oil`, `sdk`, `svelte`, `kg`, `cluster`, ...) -- forcing a
;; multi-category split here would invent structure the data doesn't have.
;; This entity is modeled as ONE category (:actor) instead.
;;
;; Backlog (stock) = github-total - west-registered-t1.
;; Reg rate (flow, repos/day) = (west-registered-t1 - west-registered-t0) /
;;   days -- a REAL observed average over a REAL dated window, not a guess.
{:as-of "2026-07-21"

 :window
 {:t0 "2026-07-19T12:48:56+09:00"
  :t0-source "com-junkawasaki/root git commit 6765878ea38f601bb8d1c448b7d5fd01a2685ebd (oldest commit in local shallow clone history at observation time), manifest/west.yml as of that commit"
  :t1 "2026-07-21T12:47:41+09:00"
  :t1-source "com-junkawasaki/root git commit d912e386e52a064cdf8f7e58777f6425b0297662 (HEAD at observation time), manifest/west.yml"
  :days 1.9991
  :note "same window as cloud-itonami-fleet-xmile-seed.edn's re-observation and kotoba-lang-fleet-xmile-seed.edn (all three built from the same pair of manifest/west.yml snapshots for a consistent, comparable rate basis). etzhayyim org's total com-etzhayyim-* repo count was independently re-confirmed unchanged (613) between entities-seed.edn's 2026-07-20 observation and this file's own 2026-07-21 `gh api` call, so all of west-registered's movement in the window is genuine catch-up registration, not new repo creation diluting the count."}

 ;; :github-total -- `gh api orgs/etzhayyim/repos --paginate --jq '.[].name'`,
 ;;   filtered to names starting with `com-etzhayyim-`, run 2026-07-21
 ;;   (authenticated call -- includes the org's private repos, same as
 ;;   entities-seed.edn's own :etzhayyim-actors :actor-repos source; the
 ;;   public, unauthenticated repo count for this org is much smaller).
 ;; :west-registered-t0/:west-registered-t1 -- exact-basename match against
 ;;   `path: orgs/etzhayyim/com-etzhayyim-*` in manifest/west.yml, counted
 ;;   at the two commits above.
 :categories
 [{:id :actor :github-total 613 :west-registered-t0 189 :west-registered-t1 546}]

 :reconciliation-note
 "613/613 GitHub com-etzhayyim-* repos accounted for by this single
  category (no residual, unlike cloud-itonami's 2-repo meta-repo
  exclusion) -- every one of these names does start with `com-etzhayyim-`
  by construction of the filter itself."}
